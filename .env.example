OWNER_JID=your_number_here@s.whatsapp.net

# Optional Speech‑to‑Text service (POST raw OGG audio, return JSON { transcription: "..." })
STT_URL=
STT_API_KEY=

# External hook configuration (optional)
HOOK_ENABLE=false
HOOK_URL=

# Logging level (pino) – choose "info", "error", etc.
LOG_LEVEL=info

# Optional: force the bot to use this JID as its own identity for self‑replies.
# This is useful for testing or when you want a stable JID without waiting for the login handshake.
# SELF_JID=1234567890@s.whatsapp.net

# Destination JID used for the silent auto‑reply (default for non‑override case).
# If set, the bot will send the placeholder reply to this JID instead of the sender.
# DEFAULT_REPLY_JID=1234567890@s.whatsapp.net

# Placeholder for external webhook (masked payload)
# API_URL=https://httpbin.org/post
